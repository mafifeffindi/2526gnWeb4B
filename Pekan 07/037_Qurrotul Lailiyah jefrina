<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Website Sederhana </title>

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            margin: 0;
            background: linear-gradient(to right, #667eea, #764ba2);
            color: #333;
        }

        header {
            background: transparent;
            color: white;
            text-align: center;
            padding: 30px 20px;
        }

        header h1 {
            margin: 0;
            font-size: 40px;
        }

        nav {
            display: flex;
            justify-content: center;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            padding: 15px;
        }

        nav a {
            color: white;
            margin: 0 15px;
            text-decoration: none;
            font-weight: bold;
            transition: 0.3s;
        }

        nav a:hover {
            color: #e00c2f;
            transform: scale(1.1);
        }

        .container {
            max-width: 800px;
            margin: 40px auto;
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }

        h2 {
            color: #764ba2;
        }

        h3 {
            color: #667eea;
        }

        ul {
            padding-left: 20px;
        }

        ul li {
            margin: 10px 0;
        }

        footer {
            text-align: center;
            padding: 20px;
            color: white;
            margin-top: 30px;
        }

        .btn {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background: #764ba2;
            color: white;
            border-radius: 25px;
            text-decoration: none;
            transition: 0.3s;
        }

        .btn:hover {
            background: #5a3c8c;
        }
    </style>

</head>

<body>

<header>
    <h1>Website Percobaan</h1>
    <p>Belajar HTML & CSS Modern</p>
</header>

<nav>
    <a href="#">Beranda</a>
    <a href="#">Tentang</a>
    <a href="#">Layanan</a>
    <a href="#">Kontak</a>
</nav>

<div class="container">
    <h2>Halo semua</h2>
    <p>
        Ini adalah percobaan web sederhana
    </p>

    <h3>Yang Dipelajari</h3>
    <ul>
        <li>HTML dasar</li>
        <li>CSS modern</li>
        <li>Layout responsif</li>
        <li>Efek hover & animasi</li>
    </ul>

    <a href="#" class="btn">Pelajari Lebih Lanjut</a>
</div>

<footer>
    <p>© 2026 - by Laily </p>
</footer>

</body>
</html>
