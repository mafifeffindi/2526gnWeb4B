<p>Belajar HTML, CSS, dan JavaScript Dasar</p>

</header>

<!-- MENU NAVIGASI WEBSITE -->

<nav>

<a onclick="tampilkanHalaman('home')">Home</a>

<a onclick="tampilkanHalaman('profil')">Profil</a>

<a onclick="tampilkanHalaman('kontak')">Kontak</a>

</nav>


