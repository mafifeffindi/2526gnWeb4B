<style>

/* ===================================== */
/* STYLE UNTUK MENGATUR TAMPILAN WEBSITE */
/* ===================================== */

/* Mengatur tampilan dasar halaman */
body{
font-family:Arial, sans-serif; 
margin:0; 
background:#e8f5e9; /* warna background diganti hijau muda */
}

/* Header atau bagian atas website */
header{
background:#2e7d32; /* hijau tua */
color:white;
padding:15px;
text-align:center;
}

/* Menu navigasi */
nav{
background:#388e3c; /* hijau menu */
padding:10px;
text-align:center;
}

/* Link pada menu */
nav a{
color:white;
margin:10px;
text-decoration:none;
font-weight:bold;
cursor:pointer;
}

/* Efek ketika mouse diarahkan ke menu */
nav a:hover{
color:#c8e6c9; /* hijau terang */
}

/* Container untuk isi halaman */
.container{
display:none;
padding:20px;
margin:20px;
background:white;
border-radius:8px;
}

/* Style tabel biodata */
table{
border-collapse:collapse;
width:350px;
}

td{
padding:8px;
}

/* Footer website */
footer{
background:#2e7d32; /* hijau footer */
color:white;
text-align:center;
padding:10px;
margin-top:20px;
}

</style>

<script>

/* ====================================== */
/* FUNGSI JAVASCRIPT UNTUK MENAMPILKAN HALAMAN */
/* ====================================== */

function tampilkanHalaman(id){

var halaman=document.getElementsByClassName("container");

for(var i=0;i<halaman.length;i++){
halaman[i].style.display="none";
}

document.getElementById(id).style.display="block";

}

</script>

</head>

